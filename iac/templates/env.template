# Environment variable template for the Tabiya Livelihoods Classifier.
#
# This file is committed to git and defines the required env var keys.
# The actual values are stored in GCP Secret Manager under the secret named
# "env-vars" in each environment's GCP project, and are never committed.
#
# scripts/prepare.py fetches the "env-vars" secret, validates it against this
# template, and writes it to a local .env.{stack} file before pulumi up runs.
#
# Syntax:
#   KEY=<description>          — required, any non-empty value
#   KEY=/regex/                — required, must match regex
#   KEY=/.*/                   — optional (regex matches empty string)

# MongoDB Atlas connection URI for the classifier application database
MONGODB_URI=<mongodb+srv://...>

# MongoDB database name for the classifier application
MONGODB_DB_NAME=<database-name>

# HuggingFace access token — required to pull tabiya/roberta-base-job-ner
HF_TOKEN=<hf_...>

# MongoDB Atlas connection URI for the taxonomy/embeddings database
TAXONOMY_MONGODB_URI=<mongodb+srv://...>
