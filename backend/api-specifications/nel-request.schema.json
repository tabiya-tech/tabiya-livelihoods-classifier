{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nel-request",
  "title": "NEL Request",
  "type": "object",
  "required": ["entities"],
  "properties": {
    "entities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["text", "entity_type"],
        "properties": {
          "text": { "type": "string", "minLength": 1 },
          "entity_type": {
            "type": "string",
            "enum": ["occupation", "skill", "qualification"]
          }
        },
        "additionalProperties": false
      }
    },
    "options": {
      "type": "object",
      "properties": {
        "top_k": { "type": "integer", "minimum": 1, "maximum": 50 },
        "min_similarity": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
