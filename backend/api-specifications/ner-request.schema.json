{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ner-request",
  "title": "NER Request",
  "type": "object",
  "required": ["text"],
  "properties": {
    "text": {
      "type": "string",
      "minLength": 1,
      "description": "Job-related text to extract entities from"
    },
    "entity_types": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["occupation", "skill", "qualification", "experience", "domain"]
      },
      "description": "Optional filter: only return entities of these types"
    }
  },
  "additionalProperties": false
}
