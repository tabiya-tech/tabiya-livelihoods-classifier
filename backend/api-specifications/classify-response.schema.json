{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "classify-response",
  "title": "Classify Response",
  "type": "object",
  "required": ["classification", "metadata"],
  "properties": {
    "classification": {
      "type": "object",
      "required": ["entities", "entity_counts"],
      "properties": {
        "entities": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["entity_type", "surface_form", "span"],
            "properties": {
              "entity_type": { "type": "string" },
              "surface_form": { "type": "string" },
              "span": {
                "type": "object",
                "required": ["start", "end"],
                "properties": {
                  "start": { "type": "integer" },
                  "end": { "type": "integer" }
                }
              },
              "linked_entities": {
                "type": "array",
                "items": { "type": "object" }
              }
            }
          }
        },
        "entity_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["classifier_version", "model_name", "linker_model", "processing_time_ms", "input_text_hash"],
      "properties": {
        "classifier_version": { "type": "string" },
        "model_name": { "type": "string" },
        "linker_model": { "type": "string" },
        "processing_time_ms": { "type": "number" },
        "input_text_hash": { "type": "string" }
      }
    }
  }
}
