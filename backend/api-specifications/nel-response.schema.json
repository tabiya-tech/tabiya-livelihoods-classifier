{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nel-response",
  "title": "NEL Response",
  "type": "object",
  "required": ["linked_entities", "metadata"],
  "properties": {
    "linked_entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["input_text", "entity_type", "matches"],
        "properties": {
          "input_text": { "type": "string" },
          "entity_type": { "type": "string" },
          "matches": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["similarity_score", "taxonomy", "label"],
              "properties": {
                "similarity_score": { "type": "number" },
                "taxonomy": { "type": "string" },
                "label": { "type": "string" },
                "code": { "type": "string" },
                "uri": { "type": "string" },
                "eqf_level": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "metadata": {
      "type": "object",
      "required": ["linker_model", "taxonomy", "processing_time_ms"],
      "properties": {
        "linker_model": { "type": "string" },
        "taxonomy": { "type": "string" },
        "processing_time_ms": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
