# Tabiya Livelihoods Classifier — Environment Variables
#
# 1. Copy this file:  cp .env.example .env
# 2. Fill in the values below.

# ─── NER Service ──────────────────────────────────────────────────────────────

# REQUIRED — HuggingFace access token for the NER model.
# Request access to tabiya/roberta-base-job-ner, then create a
# read token at https://huggingface.co/settings/tokens
HF_TOKEN=

# NER model name (HuggingFace repo or local path)
NER_MODEL=tabiya/roberta-base-job-ner

# ─── NEL Service ──────────────────────────────────────────────────────────────

# Sentence embedding model for ESCO linking
LINKER_MODEL=all-MiniLM-L6-v2

# Path to directory containing occupations_augmented.csv, skills.csv,
# qualifications.csv, and their embedding cache folders.
# Defaults to backend/nel/nel/files (symlink to inference/files recommended).
# NEL_FILES_PATH=

# ─── Classify Service ─────────────────────────────────────────────────────────

# Internal service URLs (used by classify-api to call NER and NEL)
NER_API_URL=http://localhost:5002
NEL_API_URL=http://localhost:5003

# URL for the docs site (shown in the app sidebar)
VITE_DOCS_URL=http://localhost:5174

CLASSIFIER_VERSION=1.0.0

# ─── API Limits ───────────────────────────────────────────────────────────────

MAX_TEXT_LENGTH=50000
MAX_BATCH_SIZE=500
MAX_ENTITIES_PER_REQUEST=200
MAX_TOP_K=50

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# Required for API key validation and per-user config resolution.
APPLICATION_MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=tabiya-classifier

# Cache TTL (seconds) for API key → user config lookups
API_KEY_CACHE_TTL=300

# ─── Environment configuration ───────────────────────────────────────────
TARGET_ENVIRONMENT_TYPE=local