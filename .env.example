# Classifier Service — Environment Variables
# 1. Copy this file:  cp .env.example .env
# 2. Fill in the values below.

# ── HuggingFace (for NER model) ─────────────────────────────────
HF_TOKEN=

# ── API URLs (for classify server + run_classifier) ──────────────
# Docker Compose (separate containers): use service names — compose file sets these.
# Local dev / all-in-one container: use localhost.
NER_API_URL=http://ner-api:5002
NEL_API_URL=http://nel-api:5003
CLASSIFY_API_URL=http://classify-api:5001

# ── Model Configuration ─────────────────────────────────────────
NER_MODEL=tabiya/roberta-base-job-ner
LINKER_MODEL=all-MiniLM-L6-v2

# ── API Limits ──────────────────────────────────────────────────
MAX_TEXT_LENGTH=50000
MAX_BATCH_SIZE=500
MAX_ENTITIES_PER_REQUEST=200
MAX_TOP_K=50

# ── Classifier Job (run_classifier.py) ───────────────────────────
# Target country: zambia | kenya (default: zambia)
TARGET_COUNTRY=zambia

# MongoDB — use same vars as scraper for consistency
ZAMBIA_MONGODB_URI=
ZAMBIA_DATABASE_NAME=ZambiaJobs
KENYA_MONGODB_URI=
KENYA_DATABASE_NAME=KenyaJobs
# Fallback when using single country
# APPLICATION_MONGODB_URI=
# APPLICATION_DATABASE_NAME=jobs

# Collections (defaults shown)
SOURCE_COLLECTION=scraped_jobs
TARGET_COLLECTION=classified_jobs
ERRORS_COLLECTION=classifier_errors

# Optional: limit jobs per run (empty = all)
# MAX_JOBS=100
