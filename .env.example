# Classifier Service — Environment Variables
#
# 1. Copy this file:  cp .env.example .env
# 2. Fill in the values below.

# ── HuggingFace (for NER model) ─────────────────────────────────
HF_TOKEN=

# API URLs (required for classify server / workers calling the APIs)
NER_API_URL=http://localhost:5002
NEL_API_URL=http://localhost:5003
CLASSIFY_API_URL=http://localhost:5001

# ── Model Configuration ─────────────────────────────────────────
NER_MODEL=tabiya/roberta-base-job-ner
LINKER_MODEL=all-MiniLM-L6-v2

# ── API Limits ──────────────────────────────────────────────────
MAX_TEXT_LENGTH=50000
MAX_BATCH_SIZE=500
# Cap concurrent /v1/classify + batch job pipelines (shared across all requests).
MAX_CONCURRENT_CLASSIFY_OPS=20
MAX_ENTITIES_PER_REQUEST=200
MAX_TOP_K=50

CLASSIFIER_VERSION=1.0.0

# URL for the docs site (shown in the app sidebar), if using the frontend
# VITE_DOCS_URL=http://localhost:5174

# MongoDB — classify API (API keys, user config, batch jobs)
APPLICATION_MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=tabiya-classifier
# Default (omit var): strict TLS validation. Set to true only if required (not recommended in production).
MONGODB_TLS_ALLOW_INVALID=false
# Cache TTL (seconds) for API key → user config lookups
API_KEY_CACHE_TTL=300

# MongoDB — change-stream worker only (if different DB/name from classify)
# APPLICATION_MONGODB_URI=...
# APPLICATION_DATABASE_NAME=db-name

# "local" = expose internal exception messages on 502 / batch errors (dev only).
TARGET_ENVIRONMENT_TYPE=local
